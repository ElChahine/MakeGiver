{% extends 'base.html.twig' %}

{% block title %}Accueil - Je Demain{% endblock %}

{% block body %}
<style>
    .hero-section {
        padding: 4rem 0 3rem;
        position: relative;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
    }

    .hero-subtitle {
        font-size: 1.35rem;
        color: #6B7280;
        margin-bottom: 3rem;
        font-weight: 400;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }

    .action-card {
        background: white;
        border-radius: 20px;
        padding: 3rem 2.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid transparent;
        position: relative;
        overflow: hidden;
    }

    .action-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 5px;
        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s ease;
    }

    .action-card:hover::before {
        transform: scaleX(1);
    }

    .action-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        border-color: rgba(79, 70, 229, 0.2);
    }

    .action-card .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
        transition: all 0.3s ease;
    }

    .action-card:hover .icon-wrapper {
        transform: rotate(5deg) scale(1.1);
    }

    .card-primary .icon-wrapper {
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(79, 70, 229, 0.05) 100%);
        color: var(--primary-color);
    }

    .card-secondary .icon-wrapper {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
        color: var(--secondary-color);
    }

    .action-card h2 {
        font-size: 1.75rem;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .action-card p {
        color: #6B7280;
        font-size: 1.05rem;
        margin-bottom: 2rem;
        line-height: 1.7;
    }

    .btn-action {
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        border: 2px solid;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-transform: none;
        letter-spacing: 0.3px;
    }

    .btn-action i {
        transition: transform 0.3s ease;
    }

    .btn-action:hover i {
        transform: translateX(5px);
    }

    .btn-primary-action {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        color: white;
        border-color: transparent;
    }

    .btn-primary-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -10px rgba(79, 70, 229, 0.5);
    }

    .btn-outline-action {
        background: transparent;
        color: var(--secondary-color);
        border-color: var(--secondary-color);
    }

    .btn-outline-action:hover {
        background: var(--secondary-color);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -10px rgba(16, 185, 129, 0.4);
    }

    .upcoming-section {
        background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
        padding: 3rem;
        border-radius: 20px;
        margin-top: 4rem;
        border: 2px solid #E5E7EB;
        position: relative;
        overflow: hidden;
    }

    .upcoming-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(79, 70, 229, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .upcoming-title {
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6B7280;
        margin-bottom: 1rem;
        position: relative;
    }

    .upcoming-divider {
        width: 80px;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
        margin: 1.5rem auto;
        border-radius: 2px;
    }

    .event-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        padding: 12px 24px;
        border-radius: 50px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        font-weight: 600;
        color: var(--dark-color);
        transition: all 0.3s ease;
    }

    .event-badge:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px -10px rgba(0, 0, 0, 0.2);
    }

    .event-badge i {
        color: var(--accent-color);
        font-size: 1.2rem;
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }

        .action-card {
            padding: 2rem 1.5rem;
        }

        .upcoming-section {
            padding: 2rem 1.5rem;
        }
    }
</style>

<div class="hero-section text-center">
    <h1 class="hero-title">
        Des solutions techniques pour<br>
        <span class="gradient-text">votre autonomie</span>
    </h1>
    <p class="hero-subtitle">
        Rejoignez la communauté Je Demain : Patients, Makers et Soignants co-conçoivent ensemble des solutions innovantes pour améliorer le quotidien.
    </p>

    <div class="row g-4 justify-content-center mt-4">
        <div class="col-lg-5 col-md-6">
            <div class="action-card card-primary">
                <div class="icon-wrapper">
                    <i class="bi bi-chat-dots-fill"></i>
                </div>
                <h2>J'exprime mon besoin</h2>
                <p>Vous avez une difficulté au quotidien ? Décrivez-la ici et trouvez des solutions adaptées avec l'aide de notre communauté.</p>
                <a href="{{ path('app_besoins') }}" class="btn btn-primary-action">
                    Décrire ma difficulté
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="col-lg-5 col-md-6">
            <div class="action-card card-secondary">
                <div class="icon-wrapper">
                    <i class="bi bi-lightbulb-fill"></i>
                </div>
                <h2>Je cherche une solution</h2>
                <p>Consultez notre catalogue de solutions déjà existantes et trouvez celle qui répond à vos besoins spécifiques.</p>
                <a href="{{ path('app_solutions') }}" class="btn btn-outline-action">
                    Voir le catalogue
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="upcoming-section">
        <h3 class="upcoming-title">Prochainement sur Je Demain</h3>
        <div class="upcoming-divider"></div>
        <div class="event-badge">
            <i class="bi bi-calendar-check-fill"></i>
            <span>Webinaire WeNov - Jeudi prochain à 14h</span>
        </div>
    </div>
</div>
{% endblock %}