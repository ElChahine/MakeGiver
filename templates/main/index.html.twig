{% extends 'base.html.twig' %}

{% block title %}Accueil - Je Demain{% endblock %}

{% block body %}
<div class="text-center py-5">
    <h1 class="display-4 fw-bold mb-3">Des solutions techniques pour votre autonomie</h1>
    <p class="lead mb-5 text-muted">
        Rejoignez la communauté Je Demain : Patients, Makers et Soignants co-conçoivent ensemble.
    </p>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 p-4 shadow-sm border-0 bg-light">
                <div class="card-body text-center">
                    <h2 class="h4 fw-bold">J'exprime mon besoin</h2>
                    <p class="text-muted mb-4">Vous avez une difficulté au quotidien ? Décrivez-la ici.</p>
                    <a href="{{ path('app_besoins') }}" class="btn btn-primary px-4 py-2">DÉCRIRE MA DIFFICULTÉ</a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 p-4 shadow-sm border-0 bg-light">
                <div class="card-body text-center">
                    <h2 class="h4 fw-bold">Je cherche une solution</h2>
                    <p class="text-muted mb-4">Consultez notre catalogue de solutions déjà existantes.</p>
                    <a href="{{ path('app_solutions') }}" class="btn btn-outline-primary px-4 py-2">VOIR LE CATALOGUE</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-5">
        <h3 class="h5 text-uppercase fw-light">Prochainement sur Je Demain</h3>
        <hr class="w-25 mx-auto">
        <p class="small text-muted">Webinaire WeNov - Jeudi prochain à 14h</p>
    </div>
</div>
{% endblock %}