{% extends 'base.html.twig' %}

{% block title %}Projets en cours - Je Demain{% endblock %}

{% block body %}
<style>
    .project-header {
        text-align: center;
        margin-bottom: 4rem;
        padding-top: 3rem;
    }

    .gradient-text {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
    }

    .loader-wrapper {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 2rem;
    }

    .loader-circle {
        position: absolute;
        width: 100%;
        height: 100%;
        border: 4px solid #F3F4F6;
        border-top: 4px solid var(--secondary-color);
        border-radius: 50%;
        animation: spin 1.5s linear infinite;
    }

    .loader-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 2.5rem;
        color: var(--secondary-color);
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .placeholder-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        opacity: 0.5;
        user-select: none;
        pointer-events: none;
    }

    .placeholder-card {
        background: #fdfdfd;
        border: 2px dashed #D1D5DB;
        border-radius: 20px;
        padding: 2.5rem;
        height: 250px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 15px;
    }

    .skeleton-line {
        height: 12px;
        background: #E5E7EB;
        border-radius: 6px;
        width: 100%;
    }

    .skeleton-line.short { width: 60%; }

    .coming-soon-banner {
        background: var(--dark-color);
        color: white;
        padding: 3rem;
        border-radius: 24px;
        margin-top: -100px;
        position: relative;
        z-index: 10;
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.25);
    }
</style>

<div class="container">
    <div class="project-header">
        <div class="loader-wrapper">
            <div class="loader-circle"></div>
            <i class="bi bi-tools loader-icon"></i>
        </div>
        <h1 class="display-4 fw-bold">Espace <span class="gradient-text">Projets</span></h1>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Le laboratoire collaboratif est en cours de montage. Ici, vous pourrez suivre l'évolution des prototypes, du besoin initial à la réalisation finale.
        </p>
    </div>

    <div class="placeholder-grid">
        {% for i in 1..3 %}
        <div class="placeholder-card">
            <div class="skeleton-line"></div>
            <div class="skeleton-line"></div>
            <div class="skeleton-line short"></div>
        </div>
        {% endfor %}
    </div>

    <div class="coming-soon-banner text-center">
        <h2 class="mb-3">Bientôt disponible</h2>
        <p class="mb-4 opacity-75">Suivi de conception, documentation technique et collaboration en temps réel.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="{{ path('app_solutions') }}" class="btn btn-outline-light px-4 py-2">
                Voir les solutions finies
            </a>
            <a href="{{ path('app_besoins') }}" class="btn btn-primary px-4 py-2" style="background: var(--secondary-color); border: none;">
                Soumettre un projet
            </a>
        </div>
    </div>
</div>
{% endblock %}