<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Je Demain{% endblock %}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <header class="p-3 border-bottom">
            <div class="container d-flex justify-content-between align-items-center">
                <a href="{{ path('app_home') }}" class="fw-bold text-decoration-none fs-4">JE DEMAIN</a>

                <input type="search" class="form-control w-25" placeholder="Votre recherche...">

                <div>
                    <a href="#" class="btn btn-outline-primary me-2">CONNEXION</a>
                    <a href="#" class="btn btn-primary">INSCRIPTION</a>
                </div>
            </div>
            
            <nav class="container mt-3">
                <ul class="nav">
                    <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">ACCUEIL</a></li>
                    <li class="nav-item"><a href="{{ path('app_solutions') }}" class="nav-link">SOLUTIONS</a></li>
                    <li class="nav-item"><a href="{{ path('app_besoins') }}" class="nav-link">BESOINS</a></li>
                    <li class="nav-item"><a href="#" class="nav-link">MES PROJETS</a></li>
                    <li class="nav-item"><a href="#" class="nav-link">AGENDA</a></li>
                </ul>
            </nav>
        </header>

        <main class="container my-5">
            {% block body %}{% endblock %}
        </main>

        <footer class="container py-4 border-top">
            <div class="row">
                <div class="col"><a href="#" class="text-muted">MENTIONS LÉGALES</a></div>
                <div class="col"><a href="#" class="text-muted">CONTACTS</a></div>
                <div class="col text-end"><a href="#" class="text-muted">LIENS RÉSEAUX</a></div>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>