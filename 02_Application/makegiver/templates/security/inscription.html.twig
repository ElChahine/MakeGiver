{% extends 'base.html.twig' %}

{% block title %}Inscription - MakeGiver{% endblock %}

{% block body %}
<style>
    .form-container { max-width: 640px; margin: 4rem auto; }

    .form-card {
        background: white;
        border-radius: 24px;
        padding: 3rem;
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
        border: 2px solid #F3F4F6;
    }

    .form-main-title {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--secondary-color) 0%, var(--primary-color) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-align: center;
        margin-bottom: 2rem;
    }

    .form-control-custom {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 14px 18px;
        transition: all 0.3s ease;
        width: 100%;
        font-size: 0.95rem;
    }

    .form-control-custom:focus {
        border-color: var(--secondary-color);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    .form-select-custom {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 14px 18px;
        transition: all 0.3s ease;
        width: 100%;
        font-size: 0.95rem;
        background: white;
        cursor: pointer;
        appearance: auto;
    }

    .form-select-custom:focus {
        border-color: var(--secondary-color);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    .btn-submit-green {
        width: 100%;
        padding: 18px;
        background: linear-gradient(135deg, var(--secondary-color) 0%, #059669 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px -10px rgba(16, 185, 129, 0.4);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-submit-green:hover {
        opacity: 0.9;
        transform: translateY(-2px);
        box-shadow: 0 15px 25px -10px rgba(16, 185, 129, 0.5);
    }

    /* ── Role cards ── */
    .role-card {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 14px 16px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0;
    }

    .role-card input[type="radio"] { display: none; }

    .role-card:has(input:checked) {
        border-color: var(--secondary-color);
        background: #F0FDF4;
    }

    .role-card:hover {
        border-color: #D1D5DB;
        background: #F9FAFB;
    }

    /* ── Checkbox personnalisée ── */
    .checkbox-custom-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px;
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .checkbox-custom-wrap:hover { border-color: #D1D5DB; }
    .checkbox-custom-wrap input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--secondary-color); cursor: pointer; flex-shrink: 0; }

    /* ── Erreurs ── */
    .form-errors {
        background: #FEF2F2;
        border: 2px solid #FECACA;
        border-radius: 12px;
        padding: 14px 18px;
        color: #DC2626;
        margin-bottom: 1.5rem;
    }

    .form-errors ul { margin: 0; padding-left: 1rem; }
    .field-error { color: #DC2626; font-size: 0.82rem; margin-top: 4px; }

    /* ── Séparateur de section ── */
    .section-divider {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9CA3AF;
        margin: 1.75rem 0 1rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #F3F4F6;
    }

    .optional-tag {
        font-size: 0.75rem;
        color: #9CA3AF;
        font-weight: 400;
        margin-left: 4px;
    }
</style>

<div class="container">
<div class="form-container">
<div class="form-card">

    <h1 class="form-main-title">Rejoindre la communauté</h1>

    {# Erreurs globales #}
    {% if form.vars.errors|length > 0 %}
        <div class="form-errors">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Veuillez corriger les erreurs suivantes :</strong>
            <ul class="mt-2">
                {% for error in form.vars.errors %}
                    <li>{{ error.message }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {# ── Identité ── #}
    <div class="section-divider">Identité</div>

    <div class="row mb-3">
        <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-bold">Prénom</label>
            {{ form_widget(form.prenom, {'attr': {'class': 'form-control-custom', 'placeholder': 'Jean'}}) }}
            {% if form.prenom.vars.errors|length > 0 %}
                <div class="field-error">{{ form_errors(form.prenom) }}</div>
            {% endif %}
        </div>
        <div class="col-md-6">
            <label class="form-label fw-bold">Nom</label>
            {{ form_widget(form.nom, {'attr': {'class': 'form-control-custom', 'placeholder': 'Dupont'}}) }}
            {% if form.nom.vars.errors|length > 0 %}
                <div class="field-error">{{ form_errors(form.nom) }}</div>
            {% endif %}
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Pseudo</label>
        {{ form_widget(form.pseudo, {'attr': {'class': 'form-control-custom', 'placeholder': 'MonPseudo42'}}) }}
        {% if form.pseudo.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.pseudo) }}</div>
        {% endif %}
    </div>

    {# ── Contact ── #}
    <div class="section-divider">Contact</div>

    <div class="mb-3">
        <label class="form-label fw-bold">Email</label>
        {{ form_widget(form.email, {'attr': {'class': 'form-control-custom', 'placeholder': 'votre@email.com'}}) }}
        {% if form.email.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.email) }}</div>
        {% endif %}
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Téléphone <span class="optional-tag">(optionnel)</span></label>
        {{ form_widget(form.telephone, {'attr': {'class': 'form-control-custom', 'placeholder': '06 00 00 00 00'}}) }}
        {% if form.telephone.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.telephone) }}</div>
        {% endif %}
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Région</label>
        {{ form_widget(form.region, {'attr': {'class': 'form-select-custom'}}) }}
        {% if form.region.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.region) }}</div>
        {% endif %}
    </div>

    {# ── Profil ── #}
    <div class="section-divider">Profil</div>

    {# Role cards #}
    <div class="mb-4">
        <label class="form-label fw-bold">Je suis…</label>
        <div class="d-flex flex-column gap-2">
            {% for choice in form.role %}
                <label class="role-card">
                    {{ form_widget(choice) }}
                    {% if choice.vars.value == 'Membre' %}
                        <i class="bi bi-person-heart fs-5" style="color: var(--primary-color)"></i>
                    {% elseif choice.vars.value == 'Maker' %}
                        <i class="bi bi-tools fs-5" style="color: var(--secondary-color)"></i>
                    {% else %}
                        <i class="bi bi-clipboard2-pulse fs-5" style="color: #F59E0B"></i>
                    {% endif %}
                    <span class="fw-semibold">{{ choice.vars.label }}</span>
                </label>
            {% endfor %}
        </div>
        {% if form.role.vars.errors|length > 0 %}
            <div class="field-error mt-1">{{ form_errors(form.role) }}</div>
        {% endif %}
    </div>
    {% do form.role.setRendered() %}

    {# ── Sécurité ── #}
    <div class="section-divider">Sécurité</div>

    <div class="mb-3">
        <label class="form-label fw-bold">Mot de passe</label>
        {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control-custom', 'placeholder': '••••••••'}}) }}
        {% if form.plainPassword.first.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.plainPassword.first) }}</div>
        {% endif %}
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Confirmer le mot de passe</label>
        {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control-custom', 'placeholder': '••••••••'}}) }}
        {% if form.plainPassword.second.vars.errors|length > 0 %}
            <div class="field-error">{{ form_errors(form.plainPassword.second) }}</div>
        {% endif %}
    </div>

    {# Checkbox visibilité profil #}
    <div class="mb-4">
        <label class="checkbox-custom-wrap">
            {{ form_widget(form.accepte_contact_public) }}
            <span class="fw-semibold" style="font-size:0.9rem; color:#374151;">
                J'accepte que mon profil soit visible par la communauté
            </span>
        </label>
    </div>

    <button type="submit" class="btn-submit-green">
        <i class="bi bi-person-plus-fill"></i> S'inscrire
    </button>

    {{ form_end(form, {'render_rest': false}) }}

    <p class="text-center mt-4 mb-0">
        Déjà inscrit ?
        <a href="{{ path('app_connexion') }}" class="fw-bold" style="color: var(--secondary-color)">Se connecter</a>
    </p>

</div>
</div>
</div>
{% endblock %}
