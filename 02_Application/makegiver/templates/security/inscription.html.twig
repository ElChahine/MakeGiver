{% extends 'base.html.twig' %}

{% block title %}Inscription - MakeGiver{% endblock %}

{% block body %}
<style>
    .form-container { max-width: 600px; margin: 4rem auto; }
    
    .form-card {
        background: white;
        border-radius: 24px;
        padding: 3rem;
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
        border: 2px solid #F3F4F6;
    }

    .form-main-title {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--secondary-color) 0%, var(--primary-color) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-align: center;
        margin-bottom: 2rem;
    }

    .form-control-custom {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 14px 18px;
        transition: all 0.3s ease;
        width: 100%;
    }

    .form-control-custom:focus {
        border-color: var(--secondary-color);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    .btn-submit-green {
        width: 100%;
        padding: 18px;
        background: linear-gradient(135deg, var(--secondary-color) 0%, var(--secondary-dark) 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        text-transform: uppercase;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px -10px rgba(16, 185, 129, 0.4);
        cursor: pointer;
    }

    .btn-submit-green:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .role-card {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 12px 16px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .role-card input[type="radio"] { display: none; }

    .role-card:has(input:checked),
    .role-card.selected {
        border-color: var(--secondary-color);
        background: #F0FDF4;
    }

    .form-errors {
        background: #FEF2F2;
        border: 2px solid #FECACA;
        border-radius: 12px;
        padding: 14px 18px;
        color: #DC2626;
        margin-bottom: 1.5rem;
    }

    .form-errors ul { margin: 0; padding-left: 1rem; }
</style>

<div class="form-container">
    <h1 class="form-main-title">Rejoindre la communauté</h1>

    <div class="form-card">

        {# Affichage des erreurs globales #}
        {% if form.vars.errors|length > 0 %}
            <div class="form-errors">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>Veuillez corriger les erreurs suivantes :</strong>
                <ul class="mt-2">
                    {% for error in form.vars.errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        {# Prénom / Nom #}
        <div class="row mb-4">
            <div class="col-md-6">
                <label class="form-label fw-bold">Prénom</label>
                {{ form_widget(form.prenom, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'Jean'}}) }}
                {% if form.prenom.vars.errors|length > 0 %}
                    <div class="text-danger small mt-1">{{ form_errors(form.prenom) }}</div>
                {% endif %}
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Nom</label>
                {{ form_widget(form.nom, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'Dupont'}}) }}
                {% if form.nom.vars.errors|length > 0 %}
                    <div class="text-danger small mt-1">{{ form_errors(form.nom) }}</div>
                {% endif %}
            </div>
        </div>

        {# Email #}
        <div class="mb-4">
            <label class="form-label fw-bold">Email</label>
            {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'votre@email.com'}}) }}
            {% if form.email.vars.errors|length > 0 %}
                <div class="text-danger small mt-1">{{ form_errors(form.email) }}</div>
            {% endif %}
        </div>

        {# Rôle #}
        <div class="mb-4">
            <label class="form-label fw-bold">Je suis…</label>
            <div class="d-flex flex-column gap-2">
                {% for choice in form.role %}
                    <label class="role-card">
                        {{ form_widget(choice) }}
                        {% if choice.vars.value == 'Patient' %}
                            <i class="bi bi-person-heart fs-5" style="color: var(--primary-color)"></i>
                        {% elseif choice.vars.value == 'Maker' %}
                            <i class="bi bi-tools fs-5" style="color: var(--secondary-color)"></i>
                        {% else %}
                            <i class="bi bi-clipboard2-pulse fs-5" style="color: #F59E0B"></i>
                        {% endif %}
                        <span class="fw-semibold">{{ choice.vars.label }}</span>
                    </label>
                {% endfor %}
            </div>
            {% if form.role.vars.errors|length > 0 %}
                <div class="text-danger small mt-1">{{ form_errors(form.role) }}</div>
            {% endif %}
        </div>

        {# Mot de passe #}
        <div class="mb-4">
            <label class="form-label fw-bold">Mot de passe</label>
            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control form-control-custom', 'placeholder': '••••••••'}}) }}
            {% if form.plainPassword.first.vars.errors|length > 0 %}
                <div class="text-danger small mt-1">{{ form_errors(form.plainPassword.first) }}</div>
            {% endif %}
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Confirmer le mot de passe</label>
            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control form-control-custom', 'placeholder': '••••••••'}}) }}
            {% if form.plainPassword.second.vars.errors|length > 0 %}
                <div class="text-danger small mt-1">{{ form_errors(form.plainPassword.second) }}</div>
            {% endif %}
        </div>

        <button type="submit" class="btn-submit-green">
            <i class="bi bi-person-plus-fill me-2"></i> S'inscrire
        </button>

        {{ form_end(form) }}

        <p class="text-center mt-4 mb-0">
            Déjà inscrit ? 
            <a href="{{ path('app_connexion') }}" class="fw-bold" style="color: var(--secondary-color)">Se connecter</a>
        </p>
    </div>
</div>
{% endblock %}