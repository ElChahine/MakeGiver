<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Je Demain{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        
        <style>
            :root {
                --primary-color: #4F46E5;
                --primary-dark: #4338CA;
                --primary-light: #818CF8;
                --secondary-color: #10B981;
                --secondary-dark: #059669;
                --accent-color: #F59E0B;
                --dark-color: #1F2937;
                --light-bg: #F9FAFB;
                --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
                --card-shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
                --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                color: var(--dark-color);
                background-color: #FFFFFF;
                line-height: 1.6;
                overflow-x: hidden;
            }

            h1, h2, h3, h4, h5, h6 {
                font-family: 'Poppins', sans-serif;
                font-weight: 700;
            }

            /* Header Styles */
            header {
                background: linear-gradient(135deg, #FFFFFF 0%, #F9FAFB 100%);
                border-bottom: 2px solid #E5E7EB;
                position: sticky;
                top: 0;
                z-index: 1000;
                backdrop-filter: blur(10px);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }

            .logo {
                font-family: 'Poppins', sans-serif;
                font-weight: 800;
                font-size: 1.75rem;
                background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                transition: var(--transition);
                letter-spacing: -0.5px;
            }

            .logo:hover {
                transform: scale(1.05);
                filter: brightness(1.1);
            }

            .search-container {
                position: relative;
                max-width: 400px;
            }

            .search-input {
                border: 2px solid #E5E7EB;
                border-radius: 12px;
                padding: 12px 20px 12px 45px;
                font-size: 0.95rem;
                transition: var(--transition);
                background: white;
            }

            .search-input:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
                outline: none;
                transform: translateY(-1px);
            }

            .search-icon {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: #9CA3AF;
                pointer-events: none;
            }

            .btn-custom {
                padding: 12px 28px;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.9rem;
                letter-spacing: 0.3px;
                transition: var(--transition);
                border: 2px solid transparent;
                text-transform: uppercase;
            }

            .btn-outline-custom {
                color: var(--primary-color);
                border-color: var(--primary-color);
                background: transparent;
            }

            .btn-outline-custom:hover {
                background: var(--primary-color);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -10px rgba(79, 70, 229, 0.5);
            }

            .btn-primary-custom {
                background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
                color: white;
                border: none;
            }

            .btn-primary-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -10px rgba(79, 70, 229, 0.6);
            }

            /* Navigation */
            .nav-custom {
                gap: 8px;
            }

            .nav-link-custom {
                color: var(--dark-color);
                font-weight: 600;
                font-size: 0.9rem;
                padding: 10px 20px;
                border-radius: 8px;
                transition: var(--transition);
                position: relative;
                letter-spacing: 0.3px;
            }

            .nav-link-custom::after {
                content: '';
                position: absolute;
                bottom: 6px;
                left: 20px;
                right: 20px;
                height: 3px;
                background: var(--primary-color);
                transform: scaleX(0);
                transition: transform 0.3s ease;
                border-radius: 2px;
            }

            .nav-link-custom:hover {
                color: var(--primary-color);
                background: rgba(79, 70, 229, 0.05);
            }

            .nav-link-custom:hover::after {
                transform: scaleX(1);
            }

            .nav-link-custom.active {
                color: var(--primary-color);
                background: rgba(79, 70, 229, 0.1);
            }

            /* Main Content */
            main {
                min-height: calc(100vh - 400px);
                animation: fadeIn 0.6s ease-in;
            }

            @keyframes fadeIn {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* Cards */
            .card-custom {
                border: none;
                border-radius: 16px;
                overflow: hidden;
                transition: var(--transition);
                background: white;
                box-shadow: var(--card-shadow);
                height: 100%;
            }

            .card-custom:hover {
                transform: translateY(-8px);
                box-shadow: var(--card-shadow-hover);
            }

            /* Footer */
            footer {
                background: linear-gradient(135deg, var(--dark-color) 0%, #374151 100%);
                color: white;
                padding: 3rem 0 2rem;
                margin-top: 5rem;
            }

            footer a {
                color: #D1D5DB;
                text-decoration: none;
                transition: var(--transition);
                font-weight: 500;
            }

            footer a:hover {
                color: var(--primary-light);
                transform: translateX(5px);
                display: inline-block;
            }

            /* Utility Classes */
            .gradient-text {
                background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .badge-custom {
                padding: 6px 14px;
                border-radius: 20px;
                font-weight: 600;
                font-size: 0.85rem;
            }

            /* Responsive */
            @media (max-width: 768px) {
                .logo {
                    font-size: 1.4rem;
                }
                
                .btn-custom {
                    padding: 10px 20px;
                    font-size: 0.85rem;
                }

                .nav-custom {
                    flex-wrap: wrap;
                }
            }
        </style>
        
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <!-- Bannière d'alerte pré-alpha -->
        <div id="alpha-banner" class="alpha-banner">
            <div class="container d-flex align-items-center justify-content-between py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                    <span class="fw-semibold">
                        <strong>Site en pré-alpha</strong> — Cette version est en développement actif. L'interface, les fonctionnalités et le design sont susceptibles d'évoluer.
                    </span>
                </div>
                <button class="btn-close-banner" onclick="closeBanner()" aria-label="Fermer la bannière">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <style>
            .alpha-banner {
                background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
                border-bottom: 2px solid #F59E0B;
                color: #92400E;
                font-size: 0.9rem;
                position: relative;
                z-index: 1001;
                animation: slideDown 0.5s ease-out;
            }

            @keyframes slideDown {
                from {
                    transform: translateY(-100%);
                    opacity: 0;
                }
                to {
                    transform: translateY(0);
                    opacity: 1;
                }
            }

            .alpha-banner i.bi-exclamation-triangle-fill {
                font-size: 1.2rem;
            }

            .btn-close-banner {
                background: transparent;
                border: none;
                color: #92400E;
                font-size: 1.1rem;
                cursor: pointer;
                padding: 6px 10px;
                border-radius: 6px;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .btn-close-banner:hover {
                background: rgba(146, 64, 14, 0.1);
                transform: rotate(90deg);
            }

            @media (max-width: 768px) {
                .alpha-banner span {
                    font-size: 0.8rem;
                }
                
                .alpha-banner strong {
                    display: block;
                }
            }
        </style>

        <script>
            function closeBanner() {
                const banner = document.getElementById('alpha-banner');
                banner.style.animation = 'slideUp 0.4s ease-in';
                setTimeout(() => {
                    banner.style.display = 'none';
                    // Stocker dans sessionStorage pour ne pas réafficher pendant la session
                    sessionStorage.setItem('alphaBannerClosed', 'true');
                }, 400);
            }

            // Animation de fermeture
            const style = document.createElement('style');
            style.textContent = `
                @keyframes slideUp {
                    from {
                        transform: translateY(0);
                        opacity: 1;
                    }
                    to {
                        transform: translateY(-100%);
                        opacity: 0;
                    }
                }
            `;
            document.head.appendChild(style);

            // Vérifier si la bannière a déjà été fermée dans cette session
            if (sessionStorage.getItem('alphaBannerClosed') === 'true') {
                document.getElementById('alpha-banner').style.display = 'none';
            }
        </script>

