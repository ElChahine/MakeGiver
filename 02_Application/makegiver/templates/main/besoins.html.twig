{% extends 'base.html.twig' %}

{% block title %}Besoins de la Communauté - Je Demain{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="page-header mb-5">
        <h1 class="display-4 fw-bold text-primary">Besoins de la Communauté</h1>
        <p class="lead text-muted">Découvrez les défis lancés par les patients et proposez vos solutions.</p>
    </div>

    {# --- SECTION 1 : LISTE DES BESOINS (Vient de la BDD) --- #}
    <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
        {% for besoin in besoins %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; border-left: 5px solid #4F46E5 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge rounded-pill {% if besoin.Statut == 'Ouvert' %}bg-success{% else %}bg-primary{% endif %}">
                                {{ besoin.Statut }}
                            </span>
                            <small class="text-muted"><i class="bi bi-calendar3"></i> {{ besoin.Date_Creation|date('d/m/Y') }}</small>
                        </div>

                        <h3 class="h5 fw-bold mb-3">{{ besoin.Titre_Besoin }}</h3>
                        <p class="text-secondary mb-4">{{ besoin.Description_Detaillee }}</p>

                        <div class="d-flex align-items-center pt-3 border-top">
                            <div class="bg-light rounded-circle p-2 me-3">
                                <i class="bi bi-person-fill text-primary"></i>
                            </div>
                            <div>
                                <p class="mb-0 small text-muted">Demandé par</p>
                                <p class="mb-0 fw-bold">{{ besoin.Prenom }} {{ besoin.Nom }}</p>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <a href="#" class="btn btn-primary w-100 rounded-pill">Proposer une solution</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="alert alert-light border shadow-sm">
                    <i class="bi bi-info-circle fs-2 text-primary d-block mb-3"></i>
                    <p class="mb-0">Aucun besoin n'est listé pour le moment. Soyez le premier à en exprimer un !</p>
                </div>
            </div>
        {% endfor %}
    </div>

    <hr class="my-5">

    {# --- SECTION 2 : TON FORMULAIRE (Version fonctionnelle) --- #}
    <div class="cta-section p-5 bg-dark text-white rounded-3 shadow-lg">
        <h3 class="mb-4"><i class="bi bi-pencil-square me-2"></i>Exprimez votre besoin</h3>
        <p class="mb-4">Dites-nous ce qui vous faciliterait la vie au quotidien. Les Makers vous répondront.</p>
        
        {# L'action utilise le nom de la route définie dans ton contrôleur #}
        <form action="{{ path('app_besoins') }}" method="POST" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Titre de votre besoin</label>
                {# AJOUT DE name="titre" #}
                <input type="text" name="titre" class="form-control rounded-pill" placeholder="Ex: Aide pour ouvrir les bouteilles" required>
            </div>
            <div class="col-12">
                <label class="form-label">Description détaillée</label>
                {# AJOUT DE name="description" #}
                <textarea name="description" class="form-control" rows="3" placeholder="Expliquez votre situation..." required></textarea>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-light btn-lg rounded-pill px-5 text-primary fw-bold">Envoyer le besoin</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}